    .feature:hover { transform: translateY(-10px) scale(1.03); background: rgba(255,255,255,0.15); box-shadow: 0 14px 40px rgba(0,0,0,0.3); }
    .feature i { font-size: 2.5rem; margin-bottom: 1.2rem; color: var(--secondary); display: block; transition: transform 0.4s; }
    .feature:hover i { transform: scale(1.2) rotate(12deg); }
    .feature h3 { font-size: 1.25rem; margin-bottom: 0.8rem; }
