    /* ── Why Us ── */
    .why-us { margin: 4rem 0; }
    .why-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.2rem; margin-top: 2rem; text-align: left; }
    .why-item {
      background: var(--glass); backdrop-filter: blur(8px);
      border-radius: 14px; padding: 1.5rem;
      display: flex; gap: 14px; align-items: flex-start;
