<!-- ✅ Socket.io — deferred, non-blocking -->
<script defer src="/socket.io/socket.io.js"></script>

<script>
(function() {
  'use strict';

  /* ── Mobile Nav ── */
  var menuBtn    = document.getElementById('mobileMenuBtn');
  var navLinks   = document.getElementById('navLinks');
  var navOverlay = document.getElementById('navOverlay');
  var navbar     = document.getElementById('navbar');

  function openNav() {
    navLinks.classList.add('active');
    navOverlay.classList.add('active');
    menuBtn.setAttribute('aria-expanded', 'true');
    menuBtn.setAttribute('aria-label', 'Close navigation menu');
    menuBtn.querySelector('span').innerHTML = '&#10005;';
    document.body.style.overflow = 'hidden';
  }

  function closeNav() {
    navLinks.classList.remove('active');
    navOverlay.classList.remove('active');
    menuBtn.setAttribute('aria-expanded', 'false');
    menuBtn.setAttribute('aria-label', 'Open navigation menu');
    menuBtn.querySelector('span').innerHTML = '&#9776;';
    document.body.style.overflow = '';
  }

  menuBtn.addEventListener('click', function() {
    navLinks.classList.contains('active') ? closeNav() : openNav();
  });

  navOverlay.addEventListener('click', closeNav);

  document.querySelectorAll('.nav-links a').forEach(function(link) {
    link.addEventListener('click', closeNav);
  });

  /* ── Scroll: shrink nav ── */
  var scrolled = false;
  window.addEventListener('scroll', function() {
    var should = window.scrollY > 50;
    if (should !== scrolled) {
      navbar.classList.toggle('scrolled', should);
      scrolled = should;
    }
  }, { passive: true });

  /* ── Fade-in on scroll (IntersectionObserver) ── */
  if ('IntersectionObserver' in window) {
    var fadeObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          fadeObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.fade-in').forEach(function(el) {
      fadeObserver.observe(el);
    });
  } else {
    // Fallback for old browsers
    document.querySelectorAll('.fade-in').forEach(function(el) {
      el.classList.add('visible');
    });
  }

  /* ── FAQ Accordion ── */
  document.querySelectorAll('.faq-question').forEach(function(question) {
    question.addEventListener('click', function() {
      var item     = question.closest('.faq-item');
      var isActive = item.classList.contains('active');

      // Close all
      document.querySelectorAll('.faq-item').forEach(function(i) {
        i.classList.remove('active');
        i.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
        i.querySelector('.faq-icon').textContent = '+';
      });

      if (!isActive) {
        item.classList.add('active');
        question.setAttribute('aria-expanded', 'true');
        question.querySelector('.faq-icon').textContent = '×';
      }
    });

    question.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        question.click();
      }
    });
  });

  /* ── Socket.io + Live Count ── */
  function initSocket() {
    if (typeof io === 'undefined') return;

    var socket = io();
    var liveEl = document.getElementById('liveCount');

    socket.on('updateUserCount', function(count) {
      if (liveEl) liveEl.textContent = Number(count).toLocaleString();
    });

    socket.on('waiting', function() {
      document.querySelectorAll('#startChat, #startChat2').forEach(function(btn) {
        btn.innerHTML = '<i class="fas fa-user-clock" aria-hidden="true"></i> Waiting for someone…';
        btn.disabled = true;
      });
    });

    socket.on('start-chat', function(roomId) {
      window.location.href = '/chat?room=' + roomId;
    });

    function startVideoChat(btn) {
      btn.innerHTML = '<i class="fas fa-spinner fa-spin" aria-hidden="true"></i> Finding someone…';
      btn.disabled = true;
      socket.emit('join-queue');
    }

    document.getElementById('startChat').addEventListener('click', function() {
      startVideoChat(this);
    });
    document.getElementById('startChat2').addEventListener('click', function() {
      startVideoChat(this);
    });
  }

  // Wait for socket.io script to load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      setTimeout(initSocket, 300);
    });
  } else {
    setTimeout(initSocket, 300);
  }

})();
</script>

</body>
</html>
