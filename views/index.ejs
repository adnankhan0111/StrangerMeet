    /* ── Steps ── */
    .steps-section { margin: 4rem 0; }
    .steps { display: flex; justify-content: space-between; flex-wrap: wrap; margin-top: 2.5rem; }
    .step {
      flex: 1; min-width: 240px; margin: 1rem; padding: 2rem;
