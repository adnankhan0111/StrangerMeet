    nav.scrolled { padding: 0.5rem 2rem; background: rgba(44,62,80,0.95); }
    .nav-logo { display: flex; align-items: center; text-decoration: none; transition: transform 0.3s; }
    .nav-logo:hover { transform: scale(1.05); }
    .nav-links { display: flex; list-style: none; }
    .nav-links li { margin-left: 2rem; }
    .nav-links a {
      color: var(--light); text-decoration: none; font-weight: 500;
      display: flex; align-items: center; padding: 0.5rem 0;
      position: relative; transition: color 0.3s;
    }
    .nav-links a::after {
      content: ''; position: absolute; bottom: 0; left: 0;
      width: 0; height: 2px; background: var(--secondary); transition: width 0.3s;
    }
    .nav-links a:hover { color: var(--secondary); }
    .nav-links a:hover::after { width: 100%; }
    .nav-links a i { margin-right: 8px; }
    .mobile-menu-btn { display: none; background: none; border: none; color: var(--light); font-size: 1.5rem; cursor: pointer; }

    /* ── Hero ── */
    .container { text-align: center; padding: 8rem 2rem 4rem; width: 100%; max-width: 1200px; margin: 0 auto; }

    .hero { margin-bottom: 2.5rem; animation: fadeInUp 0.8s ease-out; }

    /* ✅ H1 must be the biggest, most prominent heading — one per page */
    .hero h1 {
      font-size: clamp(1.6rem, 4vw, 2.6rem);
      font-weight: 700;
      line-height: 1.3;
      margin-bottom: 1.2rem;
      background: linear-gradient(to right, #fff, #a29bfe);
      -webkit-background-clip: text; background-clip: text; color: transparent;
    }
    .hero .subtitle {
      font-size: clamp(0.9rem, 2vw, 1.1rem);
      opacity: 0.9; max-width: 720px; margin: 0 auto 1rem; line-height: 1.7;
    }
    .hero .updated { font-size: 0.75rem; opacity: 0.6; margin-top: 0.5rem; }

    /* ── Stat badges ── */
    .stat-strip {
      display: flex; flex-wrap: wrap; justify-content: center;
      gap: 12px; margin: 1.5rem 0 2rem;
    }
    .stat-badge {
