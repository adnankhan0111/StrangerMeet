    /* ── Buttons ── */
    .btn {
      display: inline-block; padding: 16px 40px;
      background: linear-gradient(45deg, var(--primary), var(--primary-dark));
      color: var(--light); border: none; border-radius: 50px;
      font-size: 1rem; font-weight: 600; cursor: pointer;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.1);
      box-shadow: 0 10px 20px rgba(0,0,0,0.2);
      position: relative; overflow: hidden; margin: 0.5rem;
    }
    .btn:hover { transform: translateY(-4px) scale(1.05); box-shadow: 0 15px 30px rgba(0,0,0,0.3); }
    .btn:active { transform: translateY(0) scale(0.98); }
    .btn::before {
      content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      transition: left 0.5s;
    }
    .btn:hover::before { left: 100%; }
    .btn i { margin-right: 8px; }
    .btn-primary { animation: pulse 2.5s infinite; }

    /* ── Section headings ── */
    .section-heading {
      font-size: clamp(1.3rem, 3vw, 1.9rem);
      margin-bottom: 0.6rem; font-weight: 700;
