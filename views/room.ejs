const io = require('socket.io')(server);

// Queue of sockets waiting for a partner
const waitingUsers = [];

io.on('connection', (socket) => {

  // Store peer ID when client opens PeerJS
  socket.on('join-room', (roomId, peerId) => {
    socket.peerId = peerId;
    socket.join(roomId);
    socket.currentRoom = roomId;
    // Notify other users in the room (if any) about the new user
    socket.to(roomId).emit('user-connected', peerId);
  });

  // User wants to start / re‑match (from home page or Next button)
  socket.on('join-queue', (preferences) => {
    // Remove from any existing room
    if (socket.currentRoom) {
      socket.leave(socket.currentRoom);
      socket.to(socket.currentRoom).emit('partner-disconnected');
      socket.currentRoom = null;
    }

    // Remove from waiting list if already there
    const idx = waitingUsers.indexOf(socket);
    if (idx !== -1) waitingUsers.splice(idx, 1);

    // Add to queue
    waitingUsers.push(socket);

    // Match two users
    if (waitingUsers.length >= 2) {
      const user1 = waitingUsers.shift();
      const user2 = waitingUsers.shift();
      const room = `room_${Date.now()}`;

      user1.join(room);
      user2.join(room);
      user1.currentRoom = room;
      user2.currentRoom = room;

      // Both users are now in the same room.
      // Emit the peer IDs so they can connect via PeerJS.
      user2.emit('user-connected', user1.peerId);
      user1.emit('user-connected', user2.peerId);

      // Optionally send the room ID to both (already known via 'join-room')
    }
  });

  // User clicked "End" or "Next" -> leave the room
  socket.on('leave-room', (roomId) => {
    socket.leave(roomId);
    if (socket.currentRoom) {
      socket.to(socket.currentRoom).emit('partner-disconnected');
      socket.currentRoom = null;
    }
  });

  // Handle user disconnection
  socket.on('disconnect', () => {
    // Remove from waiting queue
    const idx = waitingUsers.indexOf(socket);
    if (idx !== -1) waitingUsers.splice(idx, 1);

    // Notify partner if in a room
    if (socket.currentRoom) {
      socket.to(socket.currentRoom).emit('partner-disconnected');
      socket.leave(socket.currentRoom);
    }
  });
});
