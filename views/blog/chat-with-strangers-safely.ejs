<script>
  // Mobile menu toggle
  const toggleBtn = document.getElementById('mobileMenuBtn');
  const menuPanel = document.getElementById('navLinks');
  if(toggleBtn) {
    toggleBtn.addEventListener('click', () => {
      menuPanel.classList.toggle('active');
    });
  }

  // Smooth scroll for anchor links (robust + offset for sticky header)
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      const targetId = this.getAttribute('href');
      if (targetId === "#" || targetId === "#/" || targetId === "") return;
      const targetElem = document.querySelector(targetId);
      if (targetElem) {
        e.preventDefault();
        const offsetTop = targetElem.getBoundingClientRect().top + window.scrollY - 80; // adjust for sticky navbar
        window.scrollTo({ top: offsetTop, behavior: 'smooth' });
        // Optional: close mobile menu after click on link
        if (menuPanel && menuPanel.classList.contains('active')) {
          menuPanel.classList.remove('active');
        }
      }
    });
  });

  // Ensure any broken hash initial load works (just in case)
  if (window.location.hash) {
    const id = window.location.hash;
    const element = document.querySelector(id);
    if (element) {
      setTimeout(() => {
        const offset = element.getBoundingClientRect().top + window.scrollY - 80;
        window.scrollTo({ top: offset, behavior: 'smooth' });
      }, 100);
    }
  }
</script>
